# ─────────────────────────────────────────────────────────────
# IMPORTANT: Copy this file to ".env" (Vite does NOT read .env.example)
#   cp .env.example .env
# Then restart: npm run dev
# ─────────────────────────────────────────────────────────────

# https://developer.spotify.com/dashboard → your app
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Public playlist URL or ID (paste your link or the ID only)
VITE_SPOTIFY_PLAYLIST_ID=your_playlist_id_here

# Producción — opción A (recomendada): Lambda token → secret VITE_SPOTIFY_TOKEN_URL
# VITE_SPOTIFY_TOKEN_URL=https://your-spotify-token-lambda.amazonaws.com/

# Producción — opción B: secrets SPOTIFY_CLIENT_ID + SPOTIFY_CLIENT_SECRET en GitHub Actions
# (el workflow genera un token en cada build; dura ~1 hora)

# Comments (optional overrides; defaults are the party Lambdas)
# VITE_COMMENTS_POST_URL=https://okzpybliflo6h2rxpakctwvtuy0gwazh.lambda-url.us-east-2.on.aws/
# VITE_COMMENTS_LIST_URL=https://ykc62g4w4cqsb3uwntucodncym0ejhbt.lambda-url.us-east-2.on.aws/
